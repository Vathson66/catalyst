# Makeswift Site API Key
# In the Makeswift builder, go to Settings > Host and copy the API key for the site.
MAKESWIFT_SITE_API_KEY=

# The hash visible in the subject store's URL when signed in to the store control panel.
# The control panel URL is of the form `https://store-{hash}.mybigcommerce.com`.
BIGCOMMERCE_STORE_HASH=

# A JWT Token for accessing the Storefront API. Enables server-to-server requests if allowed_cors_origins is omitted.
# See https://developer.bigcommerce.com/docs/rest-authentication/tokens#storefront-tokens
BIGCOMMERCE_STOREFRONT_TOKEN=

# A store-level API account token used for REST API actions. Optional by default, but required in
# order for some components to work properly. For example, the `CustomerGroupSlot` Makeswift component
# requires a `BIGCOMMERCE_ACCESS_TOKEN` with `read-only` scope on Customers.
# See https://support.bigcommerce.com/s/article/Store-API-Accounts?language=en_US
BIGCOMMERCE_ACCESS_TOKEN=

# The Channel ID for the selling channel being serviced by this Catalyst storefront.
# Channel ID 1 will allow you to load the same data being used on the default Stencil storefront on your store,
# but it is strongly recommended to create a new channel instead for production.
# The CLI can do this for you.
BIGCOMMERCE_CHANNEL_ID=1

# Set to true to allow the /admin route to redirect to the BigCommerce control panel.
# `false` is recommended for production. Defaults to false when not specified.
# You may also delete /admin/route.ts if you wish.
ENABLE_ADMIN_ROUTE=true

# Used by Auth.js, formerly NextAuth. To generate, run `openssl rand -hex 32` in your terminal.
AUTH_SECRET=

# Recommended so that you can use Turborepo's Remote Cache feature with signed artifacts
# https://turbo.build/repo/docs/core-concepts/remote-caching#artifact-integrity-and-authenticity-verification
# This can also be generated with `openssl rand -hex 32`, but do not re-use the value from AUTH_SECRET
TURBO_REMOTE_CACHE_SIGNATURE_KEY=

# NextJS will persists cached queries in Data Cache
# The time persisted is not defined
# https://nextjs.org/docs/app/building-your-application/caching#data-cache
# This sets a sensible revalidation target for cached requests
DEFAULT_REVALIDATE_TARGET=3600

# ── Custom Embedded Checkout ──────────────────────────────────────────────────

# Store-level management API token (X-Auth-Token) used by the custom checkout API routes.
# Generate at: BC Control Panel → Settings → API accounts → Store-level API account
# Required scopes: Carts (read), Checkouts (read/write), Orders (write), Payments (read),
#                  Customers (read), Customer Login (read/write)
# BIGCOMMERCE_STORE_HASH (above) is shared.
BC_MANAGEMENT_TOKEN=

# BC storefront origin (no trailing slash). Used as the target for the SDK proxy.
# Standard format: https://store-{hash}.mybigcommerce.com
BC_STOREFRONT_URL=

# Comma-separated offline payment method IDs to surface in the checkout UI.
# Accepted values: bank_deposit, cash_on_delivery, check_money_order
# Leave empty to show only gateway (card/wallet) methods.
CHECKOUT_OFFLINE_METHODS=

# Set to true to enable the merchant-financing (loan) UI panel in checkout.
# Requires the /api/checkout/apply-loan route to be implemented before enabling.
LOAN_ENABLED=false

# Set to true to return mock shipping/payment data from the SDK adapter without a live cart.
# Useful for local UI development. Must be false in production.
CHECKOUT_DEV_MOCK=false

# Session cache controls for checkout payment methods (browser sessionStorage).
# Keep enabled to reduce repeated API calls within a checkout session.
NEXT_PUBLIC_CHECKOUT_PAYMENT_METHODS_CACHE_ENABLED=true

# Freshness window in milliseconds for cached payment methods.
# Set to 0 to force always-fresh API reads.
NEXT_PUBLIC_CHECKOUT_PAYMENT_METHODS_CACHE_TTL_MS=60000

# Optional key prefix override for browser sessionStorage cache entries.
NEXT_PUBLIC_CHECKOUT_PAYMENT_METHODS_CACHE_PREFIX=co-payment-methods-v1

# When true, Catalyst redirects to hosted checkout right after Shipping/Billing submit
# instead of rendering the in-page Catalyst payment step.
NEXT_PUBLIC_CHECKOUT_FORCE_HOSTED_PAYMENT_FLOW=false

# When true, appends payment-only mode query flag to hosted checkout URL.
# Requires custom checkout-js script support.
NEXT_PUBLIC_CHECKOUT_HOSTED_PAYMENT_ONLY_MODE=true

# Query parameter names used for hosted checkout customization hooks.
NEXT_PUBLIC_CHECKOUT_HOSTED_RETURN_URL_PARAM=catalyst_return_url
NEXT_PUBLIC_CHECKOUT_HOSTED_PAYMENT_ONLY_PARAM=catalyst_payment_only

# Optional absolute or relative URL override for post-payment return destination.
# Default: /checkout/order-confirmation on the active Catalyst domain.
# NEXT_PUBLIC_CHECKOUT_HOSTED_RETURN_URL=https://your-catalyst-domain/checkout/order-confirmation
